# ────────────────────────────────────────────────────────────
#  Лови это как шпаргалку. Скопируй файл в `.env`
#  и подставь свои значения. Все переменные опциональны —
#  если не задать, используются дефолты из src/fanvue/config.ts
#
#  Ссылки/контакты/отзывы лучше менять прямо в админ-панели:
#     /admin/settings → "Ссылки и контакты"
#  (изменения применяются мгновенно, без пересборки).
# ────────────────────────────────────────────────────────────

# Брендинг
VITE_BRAND_NAME=FANVUE MARKET
VITE_BRAND_SUBTITLE=MARKET · 2.0

# Telegram-юзернеймы (без @)
VITE_BOT_USERNAME=FanvueMarketBot
# Admin Telegram IDs (plain, comma-separated) — fallback if hash doesn't work
VITE_ADMIN_IDS=
VITE_ADMIN_USERNAME=FanvueAdmin
VITE_SUPPORT_USERNAME=FanvueSupport
VITE_CHANNEL_USERNAME=FanvueStore
VITE_COMMUNITY_USERNAME=FanvueCommunity

# SHA-256 хеши админских Telegram UID (через запятую)
# Генерация:  node -e "require('crypto').createHash('sha256').update('fanvue:admin:v1:YOUR_UID').digest('hex')"
VITE_ADMIN_HASHES=71ff3087360063a84423e4bf06ad77cf050af2f1c0dda5d7f81bb7f07fd7e2bf

# Внешние URL
VITE_SITE_URL=
VITE_API_URL=

# Крипто-кошельки (можно так же редактировать в /admin/settings)
VITE_ADDR_TRC20=
VITE_ADDR_ERC20=
VITE_ADDR_BEP20=
VITE_ADDR_ETH=
VITE_ADDR_SOL=
VITE_ADDR_BTC=
VITE_ADDR_USDC_ETH=
VITE_ADDR_USDC_SOL=
VITE_ADDR_TON=

# QR-коды (URL картинки, опционально — если пусто, QR генерируется автоматически)
VITE_QR_TRC20=
VITE_QR_ERC20=
VITE_QR_BEP20=
VITE_QR_ETH=
VITE_QR_SOL=
VITE_QR_BTC=
VITE_QR_USDC_ETH=
VITE_QR_USDC_SOL=
VITE_QR_TON=

# Параметры
VITE_PAYMENT_TIMEOUT_MINUTES=30
VITE_REF_BONUS_PCT=5
VITE_BULK_DISCOUNT_PCT=5
VITE_BULK_DISCOUNT_MIN_QTY=3
VITE_POLL_INTERVAL_MS=6000

# ════════════════════════════════════════════════════════════
#  BACKEND (серверные переменные — НЕ попадают в клиент)
# ════════════════════════════════════════════════════════════

# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=

# Chat ID для админских уведомлений (ваш Telegram UID или ID группы)
# Узнать свой ID: отправить /start боту @userinfobot
ADMIN_CHAT_ID=

# Порт сервера
PORT=3000

# SHA-256 хеши админов (серверная копия, те же что VITE_ADMIN_HASHES)
ADMIN_HASHES=71ff3087360063a84423e4bf06ad77cf050af2f1c0dda5d7f81bb7f07fd7e2bf

# Опциональные API-ключи для блокчейн-проверки (без них работает, но с лимитами)
# Получить бесплатно: etherscan.io/register, bscscan.com/register, trongrid.io
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=
TRONGRID_API_KEY=